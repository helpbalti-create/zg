# ─── Dev — Vite reads this automatically when running `vite` / `vite dev` ─────
# VITE_* variables are inlined into the JS bundle at build time.
# Never put secrets here.

# Full URL of the Django backend.
# Used only for the OAuth login links (Google / GitHub) that must open
# Django directly — not through Vue Router or the Vite proxy.
VITE_BACKEND_URL=http://127.0.0.1:8000
