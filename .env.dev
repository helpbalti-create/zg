# ─── LOCAL DEVELOPMENT .env ──────────────────────────────────────────────────
# Copy this to .env for local dev:  copy .env.dev .env

SECRET_KEY=django-insecure-dev-only-do-not-use-in-production-1234567890abcdef
JWT_SIGNING_KEY=dev-jwt-key-replace-in-production-abcdef1234567890abcdef1234567890abcdef1234

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Leave empty = SQLite
DATABASE_URL=

# OAuth (leave empty for local dev without social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (console backend = prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@zdravy-gorod.md
