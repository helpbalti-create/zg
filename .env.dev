# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── URLS ─────────────────────────────────────────────────────────────────────
# Where the Vue frontend is hosted.
# Django uses this to redirect after OAuth (Google/GitHub) login.
# Dev:  http://localhost:3000
# Prod: https://zdravy-gorod.md
FRONTEND_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to make cross-origin requests to the API.
# Dev:  http://localhost:3000
# Prod: https://zdravy-gorod.md
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── OAUTH — GOOGLE ───────────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorised redirect URIs to add:
#   Dev:  http://127.0.0.1:8000/oauth/google/login/callback/
#   Prod: https://api.zdravy-gorod.md/oauth/google/login/callback/
GOOGLE_CLIENT_ID=404913896467-cah0t2b2dh5c5b94cr3k2vdfsisvr3pg.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# ─── OAUTH — GITHUB ───────────────────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps
# Authorization callback URL:
#   Dev:  http://127.0.0.1:8000/oauth/github/login/callback/
#   Prod: https://api.zdravy-gorod.md/oauth/github/login/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── EMAIL ────────────────────────────────────────────────────────────────────
# Dev: prints emails to console. Prod: use SMTP or a transactional provider.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@zdravy-gorod.md
